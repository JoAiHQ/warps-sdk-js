{
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "packages:publish": "turbo run build lint test && changeset publish",
    "typegen": "npm run typegen:warp && npm run typegen:brand",
    "typegen:warp": "ts-json-schema-generator --path 'packages/core/src/types/index.ts' --type 'Warp' --tsconfig 'tsconfig.typegen.json' --out 'warp-schema.json'",
    "typegen:brand": "ts-json-schema-generator --path 'packages/core/src/types/index.ts' --type 'WarpBrand' --tsconfig 'tsconfig.typegen.json' --out 'brand-schema.json'",
    "play": "turbo run build && npx tsx packages/playground/playground.ts"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "eslint-config-custom": "0.0.1",
    "prettier": "^3.8.1",
    "ts-json-schema-generator": "^2.9.0",
    "ts-node": "^10.9.2",
    "turbo": "^2.8.15"
  },
  "name": "warp-sdk-js",
  "packageManager": "npm@11.11.0",
  "workspaces": [
    "packages/*"
  ],
  "overrides": {
    "@types/node": "^22.0.0",
    "ajv": "8.18.0",
    "axios": "1.13.6",
    "qs": "6.15.0"
  }
}
